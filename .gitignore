### Xcode ###
# Xcode
#
# gitignore contributors: remember to keep this file compatible with the original one:
# https://github.com/github/gitignore/blob/main/Global/Xcode.gitignore

## User-specific configurations
xcuserdata/
*.xcuserdatad

## Build generated
build/
DerivedData/
# Локальный DerivedData, если Xcode настроен писать кэш внутрь репозитория (не путать с системным ~/Library/Developer/Xcode/DerivedData)
.DerivedData/
*.hmap
*.ipa
*.app
*.xcarchive
*.dSYM
*.dSYM.zip
*.dSYM.tar.gz
*.bcsymbolmap
**/*.dSYM/**

## Other
*.moved-aside
*.xcuserstate

# Log files
*.log

# Unit test reports
TEST*.xml

# Generated by OS
Thumbs.db

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv

# Внутри asset catalog ничего не игнорируем, даже если формат подпадает под глобальные маски (mp4/mov и т.д.).
!aivideo/Assets.xcassets/**
# `.DS_Store` только после `!`: отмена `!` иначе снова трекает служебные файлы внутри `Assets.xcassets`. Паттерн без `/` действует во всём репозитории.
.DS_Store

# JetBrains IDE
.idea/

# Cursor
.cursor/

# Внутренняя документация (пути машины, продуктовые заметки) — не в индексе репозитория
docs/

# CocoaPods
Pods/
*.xcworkspace
Podfile.lock

# Sensitive / machine-local plist (не blanket `*.plist`: нужен `aivideo/Info.plist` в репо)
# Config/APIKeys.plist
#GoogleService-Info.plist
#Config/GoogleService-Info.plist

# Локальный кэш SwiftPM внутри папки проекта (Xcode); не путать с версионируемым Package.resolved
.SourcePackages/

# Other
*.swp
*.bak
.env
